  // Atualizar escritório em tempo real quando usuário edita campos relevantes
  ['f_tipo_justica','f_desconto_conta','f_objeto_principal'].forEach(id => {
    document.getElementById(id)?.addEventListener('change', () => {
      const c = {
        tipo_justica:   document.getElementById('f_tipo_justica').value,
        desconto_conta: document.getElementById('f_desconto_conta').value,
        objeto_principal: document.getElementById('f_objeto_principal').value,
      };
      definirEscritorio(c);
    });
  });
});
