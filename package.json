function mostrarAlerta(tipo, msg) {
  const el = document.getElementById('alertMsg');
  el.style.display = 'block';
  el.className = 'alert-sb ' + (tipo==='ok'?'alert-ok-sb':'alert-err-sb');
  el.textContent = msg;
}

function limparFormulario() {
  ['npu','uf','comarca','data_ajuizamento','data_citacao','valor_causa','vara_cartorio',
   'numero_origem','tipo_justica','fase_processual','rito','tipo_documento','objeto_principal',
   'causa_raiz','pedido','desconto_conta','autor_nome','autor_cpf','advogado_nome',
   'advogado_oab','advogado_uf','advogado_escritorio'].forEach(k => {
    const el = document.getElementById('f_'+k);
    if (!el) return;
    el.value=''; el.selectedIndex=0; el.disabled=false;
    el.classList.remove('ia-filled','auto','field-ok','field-err','locked');
  });
  document.getElementById('reuList').innerHTML = '';
  reuCount = 0; addReu();
  document.getElementById('extraAdvogados').innerHTML = '';
  document.getElementById('escritorioBadge').innerHTML = '<span class="esc-badge esc-nd">Aguardando análise</span>';
  document.getElementById('escritorioRegra').textContent = 'Carregue a petição para determinação automática.';
  document.getElementById('alertasArea').innerHTML = '';
  document.getElementById('alertasWrap').style.display = 'none';
  const cont = document.getElementById('contadorPreench');
  if (cont) cont.style.display = 'none';
  document.getElementById('alertMsg').style.display = 'none';
  document.getElementById('pipeline').style.display = 'none';
}

function exportarCampos() {
  const reus = Array.from(document.querySelectorAll('.reu-row')).map(r => {
    const inp = r.querySelectorAll('input');
    return (inp[0].value||'') + (inp[1]?.value ? ' ('+inp[1].value+')' : '');
  }).filter(Boolean).join('; ');

  const linhas = [
    '=== EAGLE — CADASTRO DE PROCESSO ===',
    '',
    '--- DADOS PROCESSUAIS ---',
    `NPU CNJ: ${document.getElementById('f_npu').value}`,
    `UF: ${document.getElementById('f_uf').value}`,
    `Comarca: ${document.getElementById('f_comarca').value}`,
    `Data ajuizamento: ${document.getElementById('f_data_ajuizamento').value}`,
    `Data citação: ${document.getElementById('f_data_citacao').value}`,
    `Valor da causa: ${document.getElementById('f_valor_causa').value}`,
    `Vara/Cartório: ${document.getElementById('f_vara_cartorio').value}`,
    `Número origem: ${document.getElementById('f_numero_origem').value}`,
    `Tipo de justiça: ${document.getElementById('f_tipo_justica').value}`,
    `Rito: ${document.getElementById('f_rito').value}`,
    `Fase processual: ${document.getElementById('f_fase_processual').value}`,
    `Tipo de documento: ${document.getElementById('f_tipo_documento').value}`,
    '',
    '--- CLASSIFICAÇÃO ---',
    `Objeto principal: ${document.getElementById('f_objeto_principal').value}`,
    `Causa raiz: ${document.getElementById('f_causa_raiz').value}`,
    `Desconto em conta: ${document.getElementById('f_desconto_conta').value}`,
    `Pedido: ${document.getElementById('f_pedido').value}`,
    '',
    '--- PARTES ---',
    `Autor: ${document.getElementById('f_autor_nome').value}`,
    `CPF autor: ${document.getElementById('f_autor_cpf').value}`,
    `Réus: ${reus}`,
    '',
    '--- ADVOGADO ---',
    `Advogado: ${document.getElementById('f_advogado_nome').value}`,
    `OAB: ${document.getElementById('f_advogado_oab').value}`,
    `UF OAB: ${document.getElementById('f_advogado_uf').value}`,
    `Escritório: ${document.getElementById('f_advogado_escritorio').value}`,
    '',
    '--- EAGLE ---',
    `Escritório SBK: ${document.getElementById('escritorioBadge').textContent.trim()}`,
  ].join('\n');

  const blob = new Blob([linhas],{type:'text/plain;charset=utf-8'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href=url; a.download='eagle_cadastro_'+Date.now()+'.txt'; a.click();
  URL.revokeObjectURL(url);
}

