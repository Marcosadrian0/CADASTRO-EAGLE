// Extração de emergência quando o JSON da IA vem malformado
function extrairCamposDeTextoIA(rawText) {
  const extrai = (campo) => {
    const rx = new RegExp(`"${campo}"\\s*:\\s*"([^"]*)"`, 'i');
    const m = rawText.match(rx);
    return m ? m[1].replace(/\\n/g,' ').trim() : null;
  };
  const extraiArr = (campo) => {
    try {
      const rx = new RegExp(`"${campo}"\\s*:\\s*(\\[[^\\]]*\\])`, 'i');
      const m = rawText.match(rx);
      return m ? JSON.parse(m[1]) : [];
    } catch { return []; }
  };
  return {
    npu: extrai('npu'), uf: extrai('uf'), comarca: extrai('comarca'),
    data_ajuizamento: extrai('data_ajuizamento'), valor_causa: extrai('valor_causa'),
    vara_cartorio: extrai('vara_cartorio'), numero_origem: extrai('numero_origem'),
    tipo_justica: extrai('tipo_justica'), fase_processual: extrai('fase_processual'),
    rito: extrai('rito'), tipo_documento: extrai('tipo_documento'),
    desconto_conta: extrai('desconto_conta'), objeto_principal: extrai('objeto_principal'),
    causa_raiz: extrai('causa_raiz'), autor_nome: extrai('autor_nome'),
    autor_cpf: extrai('autor_cpf'), reus: extraiArr('reus'),
    advogado_nome: extrai('advogado_nome'), advogado_uf: extrai('advogado_uf'),
    advogado_oab: extrai('advogado_oab'), advogado_escritorio: extrai('advogado_escritorio'),
    advogados_extras: extraiArr('advogados_extras'),
    confianca: extrai('confianca'), observacoes: extrai('observacoes'),
  };
}

// ─────────────────────────────────────────────
// EXTRAÇÃO POR REGEX — FALLBACK / COMPLEMENTO
// ─────────────────────────────────────────────
function extrairRegex(txt) {
  const c = {};

  // NPU
  const npuRx = /\b(\d{7}-\d{2}\.\d{4}\.\d\.\d{2}\.\d{4})\b/;
  const mNpu = txt.match(npuRx);
  if (mNpu) c.npu = mNpu[1];
  // Fallback: nome do arquivo
  if (!c.npu) {
    const nomeArq = document.getElementById('fileName')?.textContent||'';
    const mArq = nomeArq.match(/(\d{7})[-_](\d{2})[-_.](\d{4})[-_.](\d)[-_.](\d{2})[-_.](\d{4})/);
    if (mArq) c.npu = `${mArq[1]}-${mArq[2]}.${mArq[3]}.${mArq[4]}.${mArq[5]}.${mArq[6]}`;
  }

  // UF e tipo de justiça a partir do NPU
  if (c.npu) {
    const p = c.npu.match(/\d{7}-\d{2}\.(\d{4})\.(\d)\.(\d{2})\.(\d{4})/);
    if (p) {
      if (p[2]==='8') c.tipo_justica='ESTADUAL';
      else if (p[2]==='4') c.tipo_justica='FEDERAL';
      else if (p[2]==='5') c.tipo_justica='TRABALHISTA';
      if (MAP_TRIBUNAL[p[3]]) c.uf = MAP_TRIBUNAL[p[3]];
    }
  }

  // Valor da causa
  const vRx = [
    /[Dd][áa][\s-]+se\s+[àa]\s+causa\s+o\s+valor\s+de\s+R\$\s*(\d[\d.,]*\d)/,
    /[Vv]alor\s+da\s+[Cc]ausa\s*:?\s*R\$\s*(\d[\d.,]*\d)/i
  ];
  const txtF = txt.replace(/\n/g,' ');
  for (const rx of vRx) {
    const m = txtF.match(rx);
    if (m) { c.valor_causa = 'R$ ' + m[1].trim(); break; }
  }

  // CPF autor
  const cpfM = txt.match(/(\d{3}\.\d{3}\.\d{3}-\d{2})/);
  if (cpfM) c.autor_cpf = cpfM[1];

  // OAB
  const oabM = txt.match(/OAB\/([A-Z]{2})\s*[Nn]?[.º°]?\s*([\d.]{4,9})/i);
  if (oabM) {
    c.advogado_uf = oabM[1].toUpperCase();
    c.advogado_oab = oabM[2].replace(/\D/g,'').padStart(6,'0');
  }

  // Desconto em conta — LÓGICA REFINADA
  // "Sim" = débito direto não autorizado em conta corrente (Eagle, Binclub, seguros via banco)
  // "Não" = empréstimo consignado em contracheque/folha/INSS (mesmo que mencione conta bancária como destino)
  const ehConsig = /empréstimo[s]?\s+consignado[s]?|desconto[^.]{0,60}contracheque|consignado[^.]{0,60}(?:INSS|SIAPE|folha)|margem\s+consign|superendividamento/i.test(txt);
  const ehConta = /d[eé]bito[^.]{0,100}conta\s+corrente|desconto[^.]{0,100}conta\s+corrente|cobranças?\s+indevidas?\s+(?:na|em\s+sua)\s+conta|(?:Eagle|Binclub|BINCLUB|EAGLE)[^.]{0,150}conta\s+corrente/i.test(txt);
  // Consignado tem prioridade sobre conta corrente — se é consignado, não é VERBIN
  c.desconto_conta = (ehConta && !ehConsig) ? 'Sim' : 'Não';

  // Objeto/causa raiz básicos
  if (c.desconto_conta === 'Sim') {
    c.objeto_principal = 'DÉBITO EM CONTA - ASSISTÊNCIA VERBIN';
    c.causa_raiz = 'DÉBITO EM CONTA - ASSISTÊNCIA VERBIN';
    c._verbin = true;
  } else if (/superendividamento/i.test(txt)) {
    c.objeto_principal = 'SUPERENDIVIDAMENTO';
    c.causa_raiz = 'Superendividamento';
  }

  return c;
}

// ─────────────────────────────────────────────
// MESCLAR — IA tem prioridade sobre regex
// ─────────────────────────────────────────────
function mesclarCampos(regex, ia) {
  const resultado = {...regex};
  // IA sobrescreve qualquer campo que extraiu (mesmo se regex já tinha)
  const camposIA = ['npu','uf','comarca','data_ajuizamento','valor_causa','vara_cartorio',
    'numero_origem','tipo_justica','fase_processual','rito','tipo_documento','desconto_conta',
    'objeto_principal','causa_raiz','autor_nome','autor_cpf','reus','advogado_nome',
    'advogado_uf','advogado_oab','advogado_escritorio','advogados_extras','confianca','observacoes',
    '_verbin','_fonte','_erroIA','_confianca'];
  camposIA.forEach(k => {
    const v = ia[k];
    if (v !== null && v !== undefined && v !== '' && !(Array.isArray(v) && v.length===0)) {
      resultado[k] = v;
    }
  });
  return resultado;
}

// ─────────────────────────────────────────────
// PREENCHER FORMULÁRIO
// ─────────────────────────────────────────────
function preencherFormulario(c, fonte) {
  const classeAuto = fonte === 'ia' ? 'ia-filled' : 'auto';
  let camposPreenchidos = 0;
  let camposVazios = [];

  function limparVal(v) {
    if (v === null || v === undefined) return null;
    const s = String(v).trim();
    if (s === '' || s === 'null' || s === 'undefined' || s === 'N/A' || s === 'n/a') return null;
    return s;
  }

  function set(id, val) {
    const v = limparVal(val);
    const el = document.getElementById(id);
    if (!el) return;

    if (!v) {
      // Marcar campo como não preenchido para alertas
      const label = el.closest('.fg')?.querySelector('label')?.textContent?.trim() || id;
      camposVazios.push(label.replace(/\s*\(.*\)/,'').trim());
      return;
    }

    if (el.tagName === 'SELECT') {
      const vUpper = v.toUpperCase();
      // 1. Exato por value
      for (const opt of el.options) {
        if ((opt.value||'').toUpperCase() === vUpper) {
          opt.selected = true; el.classList.add(classeAuto); camposPreenchidos++; return;
        }
      }
      // 2. Exato por text
      for (const opt of el.options) {
        if ((opt.text||'').trim().toUpperCase() === vUpper) {
          opt.selected = true; el.classList.add(classeAuto); camposPreenchidos++; return;
        }
      }
      // 3. Parcial — mínimo 8 caracteres para evitar falsos positivos
      const vParcial = vUpper.substring(0, Math.max(8, Math.floor(vUpper.length * 0.6)));
      for (const opt of el.options) {
        if ((opt.text||'').toUpperCase().includes(vParcial)) {
          opt.selected = true; el.classList.add(classeAuto); camposPreenchidos++; return;
        }
      }
      // 4. Não encontrou opção — registrar como vazio
      camposVazios.push(`${el.id.replace('f_','').replace(/_/g,' ')} (valor: ${v})`);
    } else {
      el.value = v;
      el.classList.add(classeAuto);
      camposPreenchidos++;
    }
  }

  // Limpar classes anteriores em todos os campos
  document.querySelectorAll('input,select,textarea').forEach(el => {
    el.classList.remove('ia-filled','auto','field-ok','field-err','locked');
  });

  // ── Dados processuais ──
  set('f_npu', c.npu);
  set('f_uf', c.uf);

  // Comarca: limpar sufixo de estado
  if (limparVal(c.comarca)) {
    let cidade = c.comarca.replace(/[\s,]+(ESTADO\s+DO|ESTADO\s+DA|ESTADO\s+DE|\/[A-Z]{2}|\-[A-Z]{2}).*/i,'').trim();
    cidade = cidade.split(/\s+/).slice(0,4).join(' ');
    const el = document.getElementById('f_comarca');
    if (el && cidade) { el.value = cidade; el.classList.add(classeAuto); camposPreenchidos++; }
    else camposVazios.push('Comarca');
  } else camposVazios.push('Comarca');

  set('f_data_ajuizamento', c.data_ajuizamento);
  set('f_data_citacao',     c.data_ajuizamento); // começa igual, ajuste manual posterior
  set('f_valor_causa',      c.valor_causa);
  set('f_vara_cartorio',    c.vara_cartorio);
  set('f_numero_origem',    c.numero_origem || c.npu);
  set('f_tipo_justica',     c.tipo_justica);
  set('f_rito',             c.rito);
  set('f_fase_processual',  c.fase_processual);
  set('f_tipo_documento',   c.tipo_documento);

  // ── Classificação ──
  const elObj   = document.getElementById('f_objeto_principal');
  const elCausa = document.getElementById('f_causa_raiz');
  set('f_objeto_principal', c.objeto_principal);
  set('f_causa_raiz',       c.causa_raiz);

  // VERBIN trava os campos de classificação
  if (c._verbin) {
    elObj.disabled = true;   elObj.classList.add('locked');
    elCausa.disabled = true; elCausa.classList.add('locked');
  } else {
    elObj.disabled = false; elCausa.disabled = false;
  }

  // Desconto em conta
  const descontoEl = document.getElementById('f_desconto_conta');
  const descontoVal = limparVal(c.desconto_conta);
  if (descontoEl && descontoVal) {
    const target = descontoVal.toLowerCase().startsWith('sim') ? 'Sim' : 'Não';
    for (const opt of descontoEl.options) {
      if (opt.value === target) { opt.selected = true; descontoEl.classList.add(classeAuto); camposPreenchidos++; break; }
    }
  }

  // Pedido: sempre vazio (preenchimento manual no EAGLE)
  document.getElementById('f_pedido').value = '';

  // ── Autor ──
  set('f_autor_nome', c.autor_nome);
  set('f_autor_cpf',  c.autor_cpf);

  // ── Advogado ──
  set('f_advogado_nome',       c.advogado_nome);
  set('f_advogado_uf',         c.advogado_uf);
  set('f_advogado_oab',        c.advogado_oab);
  set('f_advogado_escritorio', c.advogado_escritorio);

  // Advogados extras
  const extraWrap = document.getElementById('extraAdvogados');
  extraWrap.innerHTML = '';
  const extras = Array.isArray(c.advogados_extras) ? c.advogados_extras : [];
  extras.forEach((a, i) => {
    if (!limparVal(a?.nome)) return;
    extraWrap.innerHTML += `
      <div style="display:grid;grid-template-columns:1fr 80px 150px;gap:10px 12px;align-items:end;margin-top:10px;padding-top:10px;border-top:1px dashed var(--borda-l)">
        <div class="fg"><label>Advogado ${i+2}</label>
          <input type="text" class="${classeAuto}" value="${a.nome||''}" style="width:100%"></div>
        <div class="fg"><label>UF OAB</label>
          <input type="text" class="${classeAuto}" value="${a.uf||''}" style="width:100%"></div>
        <div class="fg"><label>Número OAB</label>
          <input type="text" class="${classeAuto}" value="${a.oab||''}" style="width:100%"></div>
      </div>`;
  });

  // ── Réus ──
  document.getElementById('reuList').innerHTML = '';
  reuCount = 0;
  const reus = Array.isArray(c.reus) ? c.reus : [];
  if (reus.length > 0) {
    reus.forEach(r => addReu(limparVal(r?.nome)||'', limparVal(r?.cnpj)||'', classeAuto));
  } else {
    addReu();
    camposVazios.push('Réus (não identificados)');
  }

  // ── Escritório ──
  definirEscritorio(c);

  // ── Contador de preenchimento ──
  atualizarContador(camposPreenchidos, camposVazios);

  // ── Alertas ──
  montarAlertas(c, camposVazios);
}

// ─────────────────────────────────────────────
// RÉUS
// ─────────────────────────────────────────────
function addReu(nome, cnpj, cls) {
  reuCount++;
  const id = 'reu_' + reuCount;
  const div = document.createElement('div');
  div.className = 'reu-row';
  div.id = id;
  div.innerHTML = `
    <input type="text" placeholder="Nome do réu" value="${nome||''}" class="${cls||''}" style="width:100%">
    <input type="text" placeholder="CNPJ / CPF" value="${cnpj||''}" class="${cls||''}" style="width:100%">
    <button class="btn-del" onclick="document.getElementById('${id}').remove()" title="Remover">✕</button>`;
  document.getElementById('reuList').appendChild(div);
}

// ─────────────────────────────────────────────
// ESCRITÓRIO — Regras SBK
// DE BELLIS  → trabalhista (prioridade máxima)
// GERBER     → desconto em conta corrente (VERBIN / cobrança indevida via banco)
// MASCARENHAS→ empréstimo consignado, superendividamento, demais cível
// ─────────────────────────────────────────────
function definirEscritorio(c) {
  const tipoJ   = c.tipo_justica  || document.getElementById('f_tipo_justica').value;
  const desconto = c.desconto_conta || document.getElementById('f_desconto_conta').value;
  const objeto   = c.objeto_principal || document.getElementById('f_objeto_principal').value;

  let esc, cls, regra;

  if (tipoJ === 'TRABALHISTA') {
    esc = 'DE BELLIS'; cls = 'esc-debellis';
    regra = 'Processo trabalhista → DE BELLIS (prioridade máxima).';
  } else if (desconto === 'Sim' || objeto === 'DÉBITO EM CONTA - ASSISTÊNCIA VERBIN') {
    esc = 'GERBER'; cls = 'esc-gerber';
    regra = 'Débito em conta corrente não autorizado (VERBIN/seguro/assistência) → GERBER.';
  } else if (objeto === 'EMPRÉSTIMO CONSIGNADO' || objeto === 'SUPERENDIVIDAMENTO') {
    esc = 'MASCARENHAS'; cls = 'esc-mascarenhas';
    regra = objeto === 'SUPERENDIVIDAMENTO'
      ? 'Superendividamento (Lei 14.181/2021) → MASCARENHAS.'
      : 'Empréstimo consignado / revisão de consignado → MASCARENHAS.';
  } else {
    esc = 'MASCARENHAS'; cls = 'esc-mascarenhas';
    regra = 'Cível não trabalhista sem VERBIN confirmado → MASCARENHAS (validar por UF).';
  }

  document.getElementById('escritorioBadge').innerHTML = `<span class="esc-badge ${cls}">${esc}</span>`;
  document.getElementById('escritorioRegra').textContent = regra;
}

// ─────────────────────────────────────────────
// CONTADOR DE PREENCHIMENTO
// ─────────────────────────────────────────────
function atualizarContador(preenchidos, vazios) {
  // Campos relevantes totais (excluindo data citação e pedido que são manuais)
  const TOTAL_CAMPOS = 18;
  const pct = Math.round((preenchidos / TOTAL_CAMPOS) * 100);

  let el = document.getElementById('contadorPreench');
  if (!el) {
    el = document.createElement('div');
    el.id = 'contadorPreench';
    el.style.cssText = 'margin-top:10px;padding:8px 10px;border-radius:6px;font-size:11px;line-height:1.6;display:block';
    document.getElementById('alertMsg').parentNode.insertBefore(el, document.getElementById('alertMsg'));
  }

  const cor = pct >= 80 ? 'var(--vok)' : pct >= 50 ? 'var(--amb)' : 'var(--err)';
  const bg  = pct >= 80 ? 'var(--vok-bg)' : pct >= 50 ? 'var(--amb-bg)' : 'var(--err-bg)';
  const brd = pct >= 80 ? 'var(--vok-b)' : pct >= 50 ? 'var(--amb-b)' : 'var(--err-b)';

  el.style.background = bg;
  el.style.border = `1px solid ${brd}`;
  el.style.color = cor;
  el.innerHTML = `
    <div style="display:flex;align-items:center;gap:6px;font-weight:600;margin-bottom:4px">
      <span style="font-size:13px">${pct >= 80 ? '✓' : pct >= 50 ? '◑' : '!'}</span>
      <span>${preenchidos} de ${TOTAL_CAMPOS} campos preenchidos (${pct}%)</span>
    </div>
    <div style="background:rgba(0,0,0,.07);border-radius:4px;height:5px;margin-bottom:${vazios.length?'6px':'0'}">
      <div style="background:${cor};height:5px;border-radius:4px;width:${pct}%;transition:width .4s"></div>
    </div>
    ${vazios.length ? `<div style="font-size:10px;opacity:.85">Preencher manualmente: ${[...new Set(vazios)].slice(0,5).join(' · ')}${vazios.length>5?' + mais...':''}</div>` : ''}
  `;
}

// ─────────────────────────────────────────────
// ALERTAS AUTOMÁTICOS
// ─────────────────────────────────────────────
function montarAlertas(c, camposVazios) {
  const lista = [];

  // Alertas baseados em campos ausentes
  if (!c.vara_cartorio)
    lista.push({tipo:'warn', msg:'Vara/Cartório não identificado — confirme no DataJud ou na capa do processo.'});
  if (!c.data_ajuizamento)
    lista.push({tipo:'warn', msg:'Data de ajuizamento não localizada — preencha manualmente.'});
  if (!c.autor_nome)
    lista.push({tipo:'err', msg:'Nome do autor não extraído — verifique a qualificação na petição.'});
  if (!c.reus || !c.reus.length)
    lista.push({tipo:'err', msg:'Réus não identificados — adicione manualmente pelo botão + Adicionar réu.'});
  if (!c.advogado_oab)
    lista.push({tipo:'warn', msg:'OAB não localizada — verifique a assinatura da petição.'});

  // Alertas de classificação
  if (c._erroIA)
    lista.push({tipo:'err', msg:`IA indisponível — preenchimento apenas por regex. Revise todos os campos.`});
  if (c.confianca === 'baixa')
    lista.push({tipo:'warn', msg:'Confiança baixa na extração — revise os campos marcados em azul com atenção.'});
  if (c.observacoes && c.observacoes !== 'null' && c.observacoes.length > 5 && c.observacoes.length < 300)
    lista.push({tipo:'warn', msg:`IA observou: ${c.observacoes}`});

  // Alerta de sucesso quando tudo OK
  if (lista.length === 0)
    lista.push({tipo:'ok', msg:'Extração completa. Revise os campos em azul antes de cadastrar no EAGLE.'});

  const area = document.getElementById('alertasArea');
  area.innerHTML = lista.map(a => `
    <div class="at ${a.tipo}">
      <span class="at-ico">${a.tipo==='warn'?'⚠':a.tipo==='err'?'✕':'✓'}</span>
      <span>${a.msg}</span>
    </div>`).join('');
  document.getElementById('alertasWrap').style.display = 'block';
}

// ─────────────────────────────────────────────
// DATAJUD
// ─────────────────────────────────────────────
const MAP_TRIBUNAL_NOME = {
  '01':'tjal','02':'tjac','03':'tjam','04':'tjap','05':'tjba','06':'tjce','07':'tjdft',
  '08':'tjes','09':'tjgo','10':'tjma','11':'tjmt','12':'tjms','13':'tjmg','14':'tjpa',
  '15':'tjpb','16':'tjpr','17':'tjpe','18':'tjpi','19':'tjrj','20':'tjrn','21':'tjrs',
  '22':'tjro','23':'tjrr','24':'tjsc','25':'tjse','26':'tjsp','27':'tjto'
};

async function consultarDataJud(npu) {
  document.getElementById('consultaWrap').style.display = 'block';
  document.getElementById('cqDot').className = 'cq-dot busy';
  document.getElementById('cqStatusTxt').textContent = 'Buscando no DataJud CNJ...';
  document.getElementById('cqResultado').innerHTML = '';
  document.getElementById('btnAplicarCq').style.display = 'none';
  dadosCq = null;

  const partes = npu.match(/\d{7}-\d{2}\.(\d{4})\.(\d)\.(\d{2})\.\d{4}/);
  if (!partes) { finalizarCq(false,'NPU inválido para consulta.'); doneStep(4,'NPU inválido'); return; }

  const codTrib = partes[3];
  const tribunalId = MAP_TRIBUNAL_NOME[codTrib];
  if (!tribunalId) { finalizarCq(false,'Tribunal não mapeado.'); doneStep(4,'não mapeado'); return; }

  const url = `https://api-publica.datajud.cnj.jus.br/api_publica_${tribunalId}/_search`;
  try {
    const resp = await fetch(url, {
      method:'POST',
      headers:{
        'Content-Type':'application/json',
        'Authorization':'ApiKey cDZHYzlZa0JadVREZDJCendFbGFDZzo2MDExMTcxMWIzYmFiOTBhMTVkNTg='
      },
      body: JSON.stringify({query:{match:{numeroProcesso:npu.replace(/[^\d]/g,'')}},size:1})
    });

    if (!resp.ok) throw new Error('HTTP ' + resp.status);
    const data = await resp.json();
    const hit = data?.hits?.hits?.[0]?._source;
    if (!hit) { finalizarCq(false,'Processo não encontrado — pode estar em sigilo ou pendente de indexação.'); doneStep(4,'não encontrado'); return; }

    dadosCq = {
      classe: hit.classe?.nome || '',
      assunto: hit.assuntos?.[0]?.nome || '',
      orgao: hit.orgaoJulgador?.nome || '',
      dataAjuizamento: hit.dataAjuizamento ? hit.dataAjuizamento.split('T')[0].split('-').reverse().join('/') : '',
      situacao: hit.movimentos?.[0]?.nome || '',
      origem: hit.processoVinculado?.[0]?.numeroProcessoVinculado || ''
    };

    const linhas = [
      dadosCq.classe && {k:'Classe',v:dadosCq.classe},
      dadosCq.assunto && {k:'Assunto',v:dadosCq.assunto},
      dadosCq.orgao && {k:'Órgão julgador',v:dadosCq.orgao},
      dadosCq.dataAjuizamento && {k:'Ajuizamento',v:dadosCq.dataAjuizamento},
      dadosCq.situacao && {k:'Situação',v:dadosCq.situacao},
    ].filter(Boolean);

    document.getElementById('cqDot').className = 'cq-dot ok';
    document.getElementById('cqStatusTxt').textContent = 'Encontrado no DataJud';
    document.getElementById('cqResultado').innerHTML = linhas.map(l =>
      `<div class="cq-row"><span class="cq-k">${l.k}</span><span class="cq-v">${l.v}</span></div>`).join('');
    document.getElementById('btnAplicarCq').style.display = 'block';
    doneStep(4,'encontrado');

  } catch(err) {
    finalizarCq(false,'DataJud indisponível — consulte o portal do tribunal manualmente.');
    doneStep(4,'indisponível');
  }
}

function finalizarCq(ok, msg) {
  document.getElementById('cqDot').className = 'cq-dot ' + (ok?'ok':'fail');
  document.getElementById('cqStatusTxt').textContent = ok ? 'Dados encontrados' : 'Consulta manual necessária';
  if (msg) document.getElementById('cqResultado').innerHTML = `<div style="color:var(--amb);font-size:11px">${msg}</div>`;
}

function aplicarDadosCq() {
  if (!dadosCq) return;
  const aplica = (id, val) => {
    if (!val) return;
    const el = document.getElementById(id);
    if (!el || el.value) return;
    if (el.tagName==='SELECT') {
      for (const opt of el.options) {
        if ((opt.text||'').toLowerCase().includes(val.toLowerCase().substring(0,10))) {
          opt.selected=true; el.classList.add('auto'); return;
        }
      }
    } else { el.value=val; el.classList.add('auto'); }
  };
  aplica('f_rito', dadosCq.classe);
  aplica('f_data_ajuizamento', dadosCq.dataAjuizamento);
  aplica('f_data_citacao', dadosCq.dataAjuizamento);
  aplica('f_vara_cartorio', dadosCq.orgao);
  if (dadosCq.origem) {
    const el = document.getElementById('f_numero_origem');
    if (el && el.value === document.getElementById('f_npu').value) {
      el.value = dadosCq.origem; el.classList.add('auto');
    }
  }
  document.getElementById('btnAplicarCq').textContent = '✓ Dados aplicados';
  document.getElementById('btnAplicarCq').disabled = true;
}

// ─────────────────────────────────────────────
// SISTEMA DE APRENDIZADO ADAPTATIVO
// ─────────────────────────────────────────────
document.getElementById('learnCampo').addEventListener('change', () => {
  document.getElementById('learnValor').placeholder = 'Valor correto para "' + (document.getElementById('learnCampo').selectedOptions[0]?.text||'') + '"';
});

async function aprenderCorrecao() {
  const campo = document.getElementById('learnCampo').value;
  const valor = document.getElementById('learnValor').value.trim();
  if (!campo || !valor) { mostrarLearnStatus('Selecione o campo e informe o valor correto.','err'); return; }
  if (!textoGlobal) { mostrarLearnStatus('Carregue um PDF antes de corrigir.','err'); return; }

  const btn = document.getElementById('btnLearn');
  btn.disabled = true;
  mostrarLearnStatus('Analisando com IA — aguarde...','busy');

  // Encontrar contexto ao redor do valor no texto
  const idx = textoGlobal.indexOf(valor);
  const trecho = idx >= 0
    ? textoGlobal.substring(Math.max(0,idx-250), idx+valor.length+250)
    : textoGlobal.substring(0,500);

  const existentes = (padroesAprendidos[campo]||[])
    .map(p=>`- "${p.padrao}" → "${p.valorExemplo}"`).join('\n');

  const prompt = `Você é especialista em extração de dados de petições judiciais brasileiras.

O usuário corrigiu o campo "${ROTULOS[campo]||campo}" para: "${valor}"

TRECHO DA PETIÇÃO:
${trecho}

${existentes ? 'PADRÕES JÁ APRENDIDOS:\n'+existentes+'\n' : ''}

Analise como "${valor}" aparece no texto e crie um padrão de extração regex JavaScript robusto para encontrá-lo em petições similares.

Responda SOMENTE em JSON puro:
{
  "padrao": "regex JS sem delimitadores, apenas o padrão",
  "tipo": "regex",
  "descricao": "1 frase descrevendo o que o padrão captura",
  "confianca": "alta|media|baixa",
  "observacao": "quando pode falhar (opcional)"
}`;

  try {
    const resp = await fetch('/api/extrair',{
      method:'POST',
      headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ tipo: 'aprender', prompt_aprendizado: prompt })
    });
    const data = await resp.json();
    const raw = (data.content?.[0]?.text||'').replace(/```json|```/g,'').trim();
    const res = JSON.parse(raw);
    if (!res.padrao) throw new Error('padrão vazio');

    if (!padroesAprendidos[campo]) padroesAprendidos[campo] = [];
    const jaExiste = padroesAprendidos[campo].find(p=>p.padrao===res.padrao);
    if (!jaExiste) {
      padroesAprendidos[campo].unshift({
        padrao:res.padrao, tipo:res.tipo||'regex', descricao:res.descricao,
        valorExemplo:valor, confianca:res.confianca,
        data: new Date().toLocaleDateString('pt-BR'), usos:0
      });
      if (padroesAprendidos[campo].length > 6) padroesAprendidos[campo] = padroesAprendidos[campo].slice(0,6);
    }
    localStorage.setItem('eagle_padroes_v3', JSON.stringify(padroesAprendidos));
    mostrarLearnStatus('✓ Padrão aprendido: "' + res.descricao + '"','ok');
    renderPadroes();

  } catch(err) {
    // Fallback: padrão literal
    if (!padroesAprendidos[campo]) padroesAprendidos[campo] = [];
    padroesAprendidos[campo].unshift({
      padrao:valor.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),
      tipo:'regex', descricao:'Valor literal: '+valor,
      valorExemplo:valor, confianca:'baixa',
      data:new Date().toLocaleDateString('pt-BR'), usos:0
    });
    localStorage.setItem('eagle_padroes_v3', JSON.stringify(padroesAprendidos));
    mostrarLearnStatus('Padrão simples salvo (IA indisponível)','ok');
    renderPadroes();
  }

  // Aplicar a correção no campo imediatamente
  const el = document.getElementById('f_'+campo);
  if (el) {
    if (el.tagName==='SELECT') {
      for (const opt of el.options) {
        if ((opt.value||opt.text||'').toUpperCase()===valor.toUpperCase()) {
          opt.selected=true; break;
        }
      }
    } else { el.value=valor; }
    el.classList.add('field-ok');
  }

  btn.disabled = false;
  document.getElementById('learnCampo').value = '';
  document.getElementById('learnValor').value = '';
}

function mostrarLearnStatus(msg, tipo) {
  const el = document.getElementById('learnStatus');
  el.textContent = msg;
  el.className = 'learn-status ' + tipo;
  el.style.display = 'block';
  if (tipo === 'ok') setTimeout(() => el.style.display='none', 4000);
}

function renderPadroes() {
  const wrap = document.getElementById('padroesWrap');
  const total = Object.values(padroesAprendidos).flat().length;
  if (total === 0) {
    wrap.innerHTML = '<div style="font-size:10px;color:var(--chumbo);font-style:italic">Nenhum padrão aprendido ainda. Corrija um campo para começar.</div>';
    return;
  }
  let html = '';
  Object.entries(padroesAprendidos).forEach(([campo, padroes]) => {
    if (!padroes.length) return;
    const rotulo = ROTULOS[campo]||campo;
    html += `<div style="margin-bottom:8px">
      <div style="font-size:9px;font-weight:600;color:var(--ciano);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px">${rotulo}</div>`;
    padroes.forEach((p,idx) => {
      html += `<div class="padrao-item">
        <div class="padrao-info">
          <div class="padrao-desc" title="${p.descricao}">${p.descricao}</div>
          <div class="padrao-meta">Ex: ${p.valorExemplo} · ${p.data}</div>
        </div>
        <span class="padrao-conf conf-${p.confianca}">${p.confianca||'?'}</span>
        <button class="btn-del-padrao" onclick="removerPadrao('${campo}',${idx})" title="Remover padrão">×</button>
      </div>`;
    });
    html += '</div>';
  });
  wrap.innerHTML = html;
}

function removerPadrao(campo, idx) {
  if (!padroesAprendidos[campo]) return;
  padroesAprendidos[campo].splice(idx,1);
  if (!padroesAprendidos[campo].length) delete padroesAprendidos[campo];
  localStorage.setItem('eagle_padroes_v3', JSON.stringify(padroesAprendidos));
  renderPadroes();
}

function limparPadroes() {
  if (!confirm('Apagar todos os padrões aprendidos?')) return;
  padroesAprendidos = {};
  localStorage.removeItem('eagle_padroes_v3');
  renderPadroes();
}

// ─────────────────────────────────────────────
// NPU CHANGE → atualiza UF/tipo de justiça em tempo real
// ─────────────────────────────────────────────
function onNpuChange(val) {
  const p = val.match(/\d{7}-\d{2}\.(\d{4})\.(\d)\.(\d{2})\.(\d{4})/);
  if (!p) return;
  const tj = {'8':'ESTADUAL','4':'FEDERAL','5':'TRABALHISTA'}[p[2]];
  if (tj) {
    const el = document.getElementById('f_tipo_justica');
    for (const opt of el.options) if (opt.value===tj) { opt.selected=true; break; }
  }
  const uf = MAP_TRIBUNAL[p[3]];
  if (uf) {
    const el = document.getElementById('f_uf');
    for (const opt of el.options) if (opt.value===uf) { opt.selected=true; break; }
  }
}

