<script>
// ─────────────────────────────────────────────
// FILTRO DE WARNINGS INOFENSIVOS DO PDF.JS
// ─────────────────────────────────────────────
// O pdf.js emite "TT: undefined function: 21" para fontes OpenType com
// instruções de hint não suportadas. É inofensivo e não afeta a extração
// de texto. Filtramos para não poluir o console.
(function() {
  const _warn  = console.warn.bind(console);
  const _error = console.error.bind(console);
  const FILTROS = [
    /TT:\s*undefined function/i,
    /fake worker/i,
    /Setting up fake worker/i,
    /Warning: TT/i
  ];
  const deveSuprimir = (...args) =>
    args.some(a => typeof a === 'string' && FILTROS.some(rx => rx.test(a)));
  console.warn  = (...args) => { if (!deveSuprimir(...args)) _warn(...args); };
  console.error = (...args) => { if (!deveSuprimir(...args)) _error(...args); };
})();

// ─────────────────────────────────────────────
// CONFIG
// ─────────────────────────────────────────────
// workerSrc configurado no script inline logo após pdf.min.js

const MAP_TRIBUNAL = {
  '01':'AC','02':'AL','03':'AM','04':'AP','05':'BA','06':'CE','07':'DF',
  '08':'ES','09':'GO','10':'MA','11':'MT','12':'MS','13':'MG','14':'PA',
  '15':'PB','16':'PR','17':'PE','18':'PI','19':'RJ','20':'RN','21':'RS',
  '22':'RO','23':'RR','24':'SC','25':'SE','26':'SP','27':'TO'
};

const ROTULOS = {
  npu:'NPU',numero_origem:'Número de origem',valor_causa:'Valor da causa',
  rito:'Rito',vara_cartorio:'Vara/Cartório',comarca:'Comarca',
  data_ajuizamento:'Data de ajuizamento',autor_nome:'Nome do autor',
  autor_cpf:'CPF do autor',objeto_principal:'Objeto principal',
  causa_raiz:'Causa raiz',desconto_conta:'Desconto em conta',
  advogado_nome:'Advogado',advogado_oab:'OAB'
};

let pdfBuffer = null;
let textoGlobal = '';
let dadosCq = null;
let padroesAprendidos = JSON.parse(localStorage.getItem('eagle_padroes_v3') || '{}');
let reuCount = 0;

// ─────────────────────────────────────────────
// UPLOAD
// ─────────────────────────────────────────────
document.getElementById('fileInput').addEventListener('change', e => {
  if (e.target.files[0]) carregarArquivo(e.target.files[0]);
});
document.getElementById('dropZone').addEventListener('dragover', e => e.preventDefault());

function onDrop(e) {
  e.preventDefault();
  e.currentTarget.classList.remove('dragover');
  const f = e.dataTransfer.files[0];
  if (f && f.name.toLowerCase().endsWith('.pdf')) carregarArquivo(f);
}

function carregarArquivo(file) {
  document.getElementById('fileName').textContent = file.name;
  document.getElementById('fileSize').textContent = (file.size/1024).toFixed(0) + ' KB';
  document.getElementById('fileCard').classList.add('show');
  document.getElementById('dropZone').style.display = 'none';
  document.getElementById('alertMsg').style.display = 'none';
  const r = new FileReader();
  r.onload = ev => { pdfBuffer = ev.target.result; analisarPDF(); };
  r.readAsArrayBuffer(file);
}

function removerArquivo() {
  pdfBuffer = null; textoGlobal = '';
  document.getElementById('fileCard').classList.remove('show');
  document.getElementById('dropZone').style.display = '';
  document.getElementById('fileInput').value = '';
  document.getElementById('pipeline').style.display = 'none';
  document.getElementById('alertMsg').style.display = 'none';
  document.getElementById('btnLearn').disabled = true;
}

// ─────────────────────────────────────────────
// PIPELINE UI
// ─────────────────────────────────────────────
function setStep(n, sub) {
  const el = document.getElementById('pipeline');
  el.style.display = 'block';
  for (let i=1;i<=4;i++) {
    const s = document.getElementById('ps'+i);
    s.classList.remove('active','done');
    if (i < n) s.classList.add('done');
    else if (i === n) s.classList.add('active');
  }
  if (sub !== undefined && document.getElementById('ps'+n+'sub')) {
    document.getElementById('ps'+n+'sub').textContent = sub||'';
  }
}
function doneStep(n, sub) {
  const s = document.getElementById('ps'+n);
  s.classList.remove('active'); s.classList.add('done');
  if (sub && document.getElementById('ps'+n+'sub')) document.getElementById('ps'+n+'sub').textContent = sub;
}

// ─────────────────────────────────────────────
// ANÁLISE PRINCIPAL
// ─────────────────────────────────────────────
async function analisarPDF() {
  if (!pdfBuffer) return;

  try {
    setStep(1);

    // ── Converter para base64 ANTES de qualquer uso do buffer ──
    // pdf.js transfere (detach) o ArrayBuffer para o worker na linha seguinte,
    // tornando-o inutilizável. Por isso convertemos primeiro.
    const b64 = arrayBufferToBase64(pdfBuffer);

    // ── Passar uma CÓPIA do buffer para o pdf.js (preserva o original) ──
    const bufferCopia = pdfBuffer.slice(0);
    const pdf = await pdfjsLib.getDocument({ data: bufferCopia }).promise;
    const totalPaginas = pdf.numPages;

    let texto = '';
    for (let p = 1; p <= Math.min(totalPaginas, 20); p++) {
      const page    = await pdf.getPage(p);
      const content = await page.getTextContent();
      let linhaAtual = '';
      let ultimaY    = null;
      let ultimaX    = null;
      content.items.forEach(item => {
        const y = Math.round(item.transform[5]);
        const x = item.transform[4];
        if (ultimaY !== null && Math.abs(y - ultimaY) > 3) {
          if (linhaAtual.trim()) texto += linhaAtual.trim() + '\n';
          linhaAtual = item.str;
        } else {
          const gap = ultimaX !== null ? (x - ultimaX) : 0;
          linhaAtual += (gap > 8 ? ' ' : '') + item.str;
        }
        ultimaX = x + (item.width || 0);
        ultimaY = y;
      });
      if (linhaAtual.trim()) texto += linhaAtual.trim() + '\n';
      texto += '\n';
    }

    // Normalização
    texto = texto
      .replace(/\r/g, '')
      .replace(/[ \t]{3,}/g, '  ')
      .replace(/\n{4,}/g, '\n\n\n')
      .replace(/([^\n])\n([^\n])/g, '$1 $2')
      .replace(/\n\n([^\n])/g, '\n\n$1')
      .trim();

    textoGlobal = texto;
    doneStep(1, `${totalPaginas} págs · ${Math.round(texto.length / 1000)}k chars`);

    if (texto.length < 80) {
      const campos = extrairRegex(texto);
      preencherFormulario(campos, 'regex');
      mostrarAlerta('err', 'PDF escaneado — texto não legível. Preencha os campos manualmente.');
      if (campos.npu) consultarDataJud(campos.npu);
      document.getElementById('btnLearn').disabled = false;
      return;
    }

    // PASSO 2: IA com PDF base64 (já convertido antes do pdf.js)
    setStep(2, 'aguarde...');
    const camposIA    = await extrairComIAComDocumento(b64, texto);
    const camposRegex = extrairRegex(texto);
    const camposFinal = mesclarCampos(camposRegex, camposIA);
    doneStep(2, camposIA._confianca || 'ok');

    // PASSO 3: Preencher
    setStep(3);
    preencherFormulario(camposFinal, camposIA._fonte || 'ia');
    doneStep(3);

    document.getElementById('btnLearn').disabled = false;

    // PASSO 4: DataJud
    if (camposFinal.npu) {
      setStep(4, 'buscando...');
      consultarDataJud(camposFinal.npu);
    } else {
      doneStep(4, 'sem NPU');
    }

    mostrarAlerta('ok', 'Análise concluída. Campos em azul = preenchidos pela IA. Revise antes de cadastrar.');

  } catch(err) {
    console.error('Erro na análise:', err);
    mostrarAlerta('err', 'Erro ao processar o PDF: ' + err.message);
    document.getElementById('pipeline').style.display = 'none';
  }
}

// Converter ArrayBuffer para base64
function arrayBufferToBase64(buffer) {
  const bytes = new Uint8Array(buffer);
  let bin = '';
  const chunk = 8192;
  for (let i = 0; i < bytes.length; i += chunk) {
    bin += String.fromCharCode(...bytes.subarray(i, i + chunk));
  }
  return btoa(bin);
}

// ─────────────────────────────────────────────
// EXTRAÇÃO POR IA — ESTRATÉGIA PRIMÁRIA: PDF como documento base64
// A IA lê o PDF diretamente, sem depender da qualidade do extrator de texto
// ─────────────────────────────────────────────
async function extrairComIAComDocumento(b64pdf, textoFallback) {
  const padroesCtx = Object.entries(padroesAprendidos).length > 0
    ? '\n\nPADRÕES APRENDIDOS COM CORREÇÕES ANTERIORES:\n' +
      Object.entries(padroesAprendidos)
        .map(([campo, ps]) => ps.map(p =>
          `- ${ROTULOS[campo]||campo}: "${p.descricao}" → ex: "${p.valorExemplo}"`).join('\n'))
        .join('\n')
    : '';

  const instrucoes = buildPromptInstrucoes(padroesCtx);

  // ── Estratégia 1: PDF como documento (mais precisa) ──
  try {
    const resp = await fetch('/api/extrair', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tipo: 'extrair_pdf',
        pdf_b64: b64pdf,
        instrucoes: instrucoes
      })
    });

    if (resp.ok) {
      const data = await resp.json();
      if (!data.error) {
        const resultado = parsearRespostaIA(data);
        if (resultado && resultado.npu) {
          resultado._fonte = 'ia';
          resultado._estrategia = 'pdf-documento';
          console.log('✅ IA via PDF documento:', resultado);
          return resultado;
        }
      }
    }
    console.warn('PDF documento falhou, tentando com texto...');
  } catch(e) {
    console.warn('Erro estratégia PDF documento:', e.message);
  }

  // ── Estratégia 2: Texto otimizado (fallback) ──
  return await extrairComIA(textoFallback);
}

// ─────────────────────────────────────────────
// EXTRAÇÃO POR IA — ESTRATÉGIA SECUNDÁRIA: texto puro
// ─────────────────────────────────────────────
async function extrairComIA(texto) {
  const padroesCtx = Object.entries(padroesAprendidos).length > 0
    ? '\n\nPADRÕES APRENDIDOS:\n' +
      Object.entries(padroesAprendidos)
        .map(([campo, ps]) => ps.map(p =>
          `- ${ROTULOS[campo]||campo}: "${p.descricao}" → ex: "${p.valorExemplo}"`).join('\n'))
        .join('\n')
    : '';

  const instrucoes = buildPromptInstrucoes(padroesCtx);

  // Montar texto otimizado: priorizar início (capa/cabeçalho) + final (valor/assinatura)
  // A capa ePROC/PJe tem toda a informação estruturada nas primeiras ~4000 chars
  const inicio = texto.substring(0, 5000);
  const fim    = texto.substring(Math.max(0, texto.length - 3000));
  const trechoEnvio = inicio + (texto.length > 8000 ? '\n\n[...trecho central omitido...]\n\n' : '') + fim;

  const prompt = instrucoes + `\n\nTEXTO DA PETIÇÃO/PROCESSO:\n${trechoEnvio}`;

  try {
    const resp = await fetch('/api/extrair', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        tipo: 'extrair_texto',
        texto: trechoEnvio,
        instrucoes: instrucoes
      })
    });

    if (!resp.ok) {
      const errBody = await resp.text().catch(() => '');
      throw new Error(`HTTP ${resp.status}: ${errBody.substring(0, 100)}`);
    }
    const data = await resp.json();
    if (data.error) throw new Error(data.error.message);

    const resultado = parsearRespostaIA(data);
    resultado._fonte = 'ia';
    resultado._estrategia = 'texto';
    resultado._confianca = resultado.confianca || 'media';
    console.log('✅ IA via texto:', resultado);
    return resultado;

  } catch(err) {
    console.error('Erro extração IA (texto):', err);
    mostrarAlerta('err', `IA indisponível — preenchimento por regex. Revise os campos.`);
    return { _fonte: 'regex', _erroIA: err.message };
  }
}

// ─────────────────────────────────────────────
// PARSEAR RESPOSTA DA IA (JSON robusto)
// ─────────────────────────────────────────────
function parsearRespostaIA(data) {
  let raw = (data.content?.[0]?.text || '').trim();
  // Remover blocos de código markdown
  raw = raw.replace(/^```json\s*/i, '').replace(/^```\s*/, '').replace(/\s*```$/, '').trim();
  // Extrair JSON se vier com texto antes/depois
  const jsonMatch = raw.match(/\{[\s\S]*\}/);
  if (jsonMatch) raw = jsonMatch[0];
  // Corrigir JSON truncado
  if (!raw.endsWith('}')) {
    const ab = (raw.match(/\{/g)||[]).length - (raw.match(/\}/g)||[]).length;
    const sq = (raw.match(/\[/g)||[]).length - (raw.match(/\]/g)||[]).length;
    // Fechar arrays abertos primeiro
    for (let i = 0; i < sq; i++) raw += ']';
    for (let i = 0; i < ab + 1; i++) raw += '}';
  }

  let resultado;
  try {
    resultado = JSON.parse(raw);
  } catch (e) {
    console.warn('JSON malformado, usando extração parcial:', e.message, '\nRAW:', raw.substring(0, 300));
    resultado = extrairCamposDeTextoIA(raw);
  }

  // Sanitizar strings "null"/"undefined" para null real
  Object.keys(resultado).forEach(k => {
    if (resultado[k] === 'null' || resultado[k] === 'undefined' || resultado[k] === 'N/A') {
      resultado[k] = null;
    }
  });

  return resultado;
}

